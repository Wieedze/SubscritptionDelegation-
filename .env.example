# ─── Network ────────────────────────────────────────────────────────────────
# Sepolia RPC (Alchemy / Infura / public)
RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# ─── Subscriber (test) ───────────────────────────────────────────────────────
# EOA owner of the DeleGator smart account. NEVER commit a real key.
SUBSCRIBER_PRIVATE_KEY=0x...

# ─── Organization (delegate that pulls the subscription) ─────────────────────
# Plain EOA that calls redeemDelegations each period and receives the funds.
ORG_PRIVATE_KEY=0x...
# Address that ultimately receives the pulled tokens (defaults to the ORG EOA).
ORG_RECIPIENT=0x...

# ─── Token ───────────────────────────────────────────────────────────────────
# MockERC20 address (filled after `forge script Deploy`).
TOKEN_ADDRESS=0x...

# ─── IPFS pinning (Pinata) ───────────────────────────────────────────────────
# JWT from https://app.pinata.cloud (Account > API Keys).
PINATA_JWT=
# Public gateway used to resolve ipfs:// links for display.
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
